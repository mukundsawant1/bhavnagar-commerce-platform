{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Bhavnagar Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Bhavnagar Dev Server (Node Path)",
			"type": "shell",
			"command": "C:\\Program Files\\nodejs\\npm.cmd",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Bhavnagar Dev Server (Explicit Node)",
			"type": "shell",
			"command": "C:\\Program Files\\nodejs\\node.exe",
			"args": [
				"C:\\Program Files\\nodejs\\node_modules\\npm\\bin\\npm-cli.js",
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Bhavnagar Dev Server (Next CLI)",
			"type": "shell",
			"command": "C:\\Program Files\\nodejs\\node.exe",
			"args": [
				"node_modules\\next\\dist\\bin\\next",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}
